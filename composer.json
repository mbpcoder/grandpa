{
  "name": "mbpcoder/grandpa",
  "authors": [
    {
      "name": "Mahdi Bagheri",
      "email": "mb.programmer@yahoo.com"
    }
  ],
  "require": {
    "php": ">=8.1",
    "ext-ftp": "*",
    "guzzlehttp/guzzle": "^7.0",
    "leafo/scssphp": "^0.7.5",
    "league/flysystem": "^3.0",
    "league/flysystem-aws-s3-v3": "^3.34",
    "league/flysystem-ftp": "^3.0",
    "league/flysystem-sftp-v3": "^3.33",
    "masbug/flysystem-google-drive-ext": "^2.5",
    "royvoetman/flysystem-gitlab-storage": "^3.1"
  },
  "suggest": {
    "vlucas/phpdotenv": "Allows loading deploy credentials from a .env file."
  },
  "autoload": {
    "psr-4": {
      "Grandpa\\": "src/"
    },
    "files": [
      "src/functions.php"
    ]
  },
  "bin": [
    "bin/grandpa"
  ],
  "scripts": {
    "deploy": "php bin/grandpa deploy",
    "schedule": "php bin/grandpa schedule:run",
    "test": "phpunit"
  },
  "require-dev": {
    "phpunit/phpunit": "^10"
  }
}
