<?php

declare(strict_types=1);

task('deploy', function () {
    $files = git()->changedFiles();

    ftp()->upload($files);
    ftp()->delete(git()->deletedFiles());

    git()->saveRevision();

    say('Deployed');
});

// Runs every minute when triggered via `php bin/grandpa schedule:run`
// (typically from a single cron entry, like Laravel's scheduler).
task('clear-cache', function () {
    ssh()->run('cd /var/www/app && php artisan cache:clear');
})->everyFiveMinutes();

task('heartbeat', function () {
    say('Still alive at ' . date('Y-m-d H:i:s'));
})->everyMinute();

// Walk one level of subdirectories under a base path, and `git pull` every
// one that is a git repository, reporting the branch and changed files.
task('git:update-all', function () {
    foreach (subDirectories('/var/www/projects') as $dir) {
        if (!git()->isRepository($dir)) {
            continue;
        }

        say($dir);
        say('  branch: ' . git()->currentBranch($dir));

        foreach (git()->pull($dir) as $line) {
            say('  ' . $line);
        }
    }
});
